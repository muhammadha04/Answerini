# Supabase (required for auth + saved games)
# Create project at https://supabase.com → Settings → API
# Project URL only — do NOT include /rest/v1 (breaks auth signup/login)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Upstash Redis (required for production live games / 300+ players)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
