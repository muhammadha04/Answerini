# Supabase (required for auth + saved games)
# Create project at https://supabase.com → Settings → API
# Project URL only — do NOT include /rest/v1 (breaks auth signup/login)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role (required on Vercel for live game rooms)
# Settings → API → service_role key (keep secret, server-only)
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis (optional but recommended for 300+ players — faster than Supabase)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
